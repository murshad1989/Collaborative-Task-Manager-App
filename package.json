    "jsonwebtoken": "^9.0.2",
    "mongobd": "^0.0.1-security.0",
    "mongodb": "^6.11.0",
    "mongoose": "^8.8.3",
    "mongoosh": "^0.0.7",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "react-router-dom": "^6.28.0"
  },
